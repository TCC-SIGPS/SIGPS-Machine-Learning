# Copie para scripts/deploy.env e preencha:
#   cp scripts/deploy.env.example scripts/deploy.env

# Usuário e host SSH da VPS (ex.: root@123.45.67.89 ou deploy@sigps.online)
VPS_USER=root
VPS_HOST=SEU_IP_OU_DOMINIO

# Pasta do módulo ML na VPS (caminho absoluto)
VPS_ML_DIR=/opt/sigps/SIGPS-Machine-Learning

# Nome do container Docker do serviço ML
ML_CONTAINER=sigps-ml
